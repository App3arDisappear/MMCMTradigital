<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.mmcm.tradigital.controller.AdminController">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <Tab text="Products">
                <VBox spacing="10">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <TableView fx:id="tblProducts" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colProdSku" text="Item Code" prefWidth="100"/>
                            <TableColumn fx:id="colProdName" text="Name" prefWidth="150"/>
                            <TableColumn fx:id="colProdCat" text="Category" prefWidth="100"/>
                            <TableColumn fx:id="colProdPrice" text="Price" prefWidth="80"/>
                            <TableColumn fx:id="colProdStock" text="Stock" prefWidth="80"/>
                        </columns>
                    </TableView>
                    <GridPane hgap="10" vgap="5">
                        <Label text="Item Code:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtSku" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtName" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <Label text="Category:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                        <ComboBox fx:id="cmbCategory" prefWidth="150" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                        <Label text="Price:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtPrice" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                        <Label text="Stock:" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtStock" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
                    </GridPane>
                    <HBox spacing="10" alignment="CENTER">
                        <Button text="Add Product" onAction="#addProduct"/>
                        <Button text="Update Selected" onAction="#editProduct"/>
                        <Button text="Delete Selected" onAction="#deleteProduct"/>
                    </HBox>
                </VBox>
            </Tab>

            <Tab text="Categories">
                <VBox spacing="10">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <TableView fx:id="tblCategories" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colCatId" text="ID" prefWidth="100"/>
                            <TableColumn fx:id="colCatName" text="Category Name" prefWidth="200"/>
                        </columns>
                    </TableView>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Category Name:"/>
                        <TextField fx:id="txtCategoryName" HBox.hgrow="ALWAYS"/>
                        <Button text="Add" onAction="#addCategory"/>
                        <Button text="Delete" onAction="#deleteCategory"/>
                    </HBox>
                </VBox>
            </Tab>
        </tabs>
    </TabPane>

    <HBox alignment="CENTER_RIGHT">
        <Button text="Back to Shop" onAction="#backToMain"/>
    </HBox>
</VBox>